{
  "name": "svelte-multistyle-ui",
  "version": "0.1.0",
  "description": "A multi-style, multi-theme Svelte 5 component library with multiple design styles and multiple color schemes",
  "type": "module",
  "license": "MIT",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./dist/components/theme.css",
    "./theme-base.css": "./dist/components/theme-base.css",
    "./components/*": "./dist/components/*"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "svelte-package -i src/lib",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build:lib",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium webkit"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "svelte": "^5.55.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.9"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "components",
    "ui-library",
    "material-design",
    "glassmorphism",
    "neumorphism",
    "brutalist",
    "cyberpunk",
    "multi-theme",
    "multi-style"
  ],
  "dependencies": {
    "dayjs": "^1.11.21",
    "prismjs": "^1.30.0"
  }
}
