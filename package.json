{
  "name": "svelte-multistyle-ui",
  "version": "0.0.11-alpha",
  "description": "A multi-style, multi-theme Svelte 5 component library with multiple design styles and multiple color schemes",
  "type": "module",
  "license": "MIT",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "svelte-multistyle-ui": "cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./dist/components/theme.css",
    "./theme-base.css": "./dist/components/theme-base.css",
    "./themes": "./dist/themes/index.js",
    "./components/*": "./dist/components/*",
    "./charts/*": "./dist/components/charts/*"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "cli",
    "!cli/**/*.test.*",
    "!cli/test.js"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/rename-bundle.js",
    "gen:theme": "node scripts/gen-theme.js",
    "gen": "node cli/bin.js generate",
    "gen:sample": "node cli/bin.js generate --input cli/fixtures/sample.yaml --output ./src/routes/demo/+page.svelte",
    "test:gen": "node cli/test.js",
    "build:lib": "node -e \"const p=require('./package.json');const m=p.version.match(/^(\\d+\\.\\d+\\.)(\\d+)(.*)$/);p.version=m[1]+(parseInt(m[2])+1)+(m[3]||'');require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\" && pnpm run gen:theme && svelte-package -i src/lib",
    "preview": "vite preview",
    "prepublishOnly": "pnpm run build:lib",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:install": "playwright install --with-deps chromium webkit"
  },
  "peerDependencies": {
    "chart.js": "^4.5.1",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "chart.js": "^4.5.1",
    "svelte": "^5.55.4",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.9"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "components",
    "ui-library",
    "material-design",
    "glassmorphism",
    "neumorphism",
    "brutalist",
    "cyberpunk",
    "multi-theme",
    "multi-style"
  ],
  "dependencies": {
    "@thisux/sveltednd": "^0.4.1",
    "dayjs": "^1.11.21",
    "js-yaml": "^4.1.0",
    "prismjs": "^1.30.0",
    "tailwind-merge": "^3.6.0"
  }
}
